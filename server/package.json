{
  "name": "lachish-businesses-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Server that monitors a WhatsApp group and extracts local business data into Firestore.",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "check:firebase": "tsx src/scripts/checkFirebase.ts",
    "test:extract": "tsx src/scripts/testExtract.ts",
    "probe:media": "tsx src/scripts/probeMedia.ts"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "ngeohash": "^0.6.3",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "undici": "^7.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
