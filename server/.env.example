# ---- HTTP API ----
PORT=3000
# Console log level: fatal|error|warn|info|debug|trace
LOG_LEVEL=info
# Full audit log file. Captures every Gemini request/response and the worker
# pipeline at LOG_FILE_LEVEL, independent of the console. Set LOG_FILE= to disable.
LOG_FILE=logs/app.log
LOG_FILE_LEVEL=debug
# Set to "production" in Docker / real deploys (disables pretty logging)
NODE_ENV=development
# Allowed CORS origins for the web client. "*" = any; otherwise comma-separated,
# e.g. https://your-app.web.app,http://localhost:5173
CORS_ORIGINS=*

# ---- WhatsApp (Baileys) ----
# Directory where the WhatsApp session is persisted. Mounted as a volume in Docker.
WA_AUTH_DIR=./auth
# The group to monitor. Easiest: leave both blank on first run, check the logs for the
# list of groups your number is in, then paste the group's JID here (looks like
# "1234567890-1234567890@g.us"). TARGET_GROUP_ID takes priority over TARGET_GROUP_NAME.
TARGET_GROUP_ID=
TARGET_GROUP_NAME=
# Backfill: if true, ingest the *recent* group history WhatsApp sends on login,
# limited to the last HISTORY_MAX_AGE_DAYS days. Does NOT pull the whole archive.
INGEST_HISTORY=false
HISTORY_MAX_AGE_DAYS=30
# If true, ask WhatsApp for the FULL on-phone history (can be very large + many AI
# calls). Leave false unless you really want everything.
WA_SYNC_FULL_HISTORY=false
# Also ingest messages you send from the linked phone itself. Handy for testing;
# keep false in production (the real organizer posts from a different number).
INGEST_FROM_ME=false
# Set to true ONLY if you see "self-signed certificate in certificate chain" errors,
# which mean your network intercepts TLS (corporate proxy / VPN / antivirus SSL scanning).
# This skips cert verification for the WhatsApp connection only (not Firebase/Gemini).
WA_ALLOW_INSECURE_TLS=false
# Verbosity of Baileys' internal logs: silent|fatal|error|warn|info|debug|trace.
# "silent" hides noisy initial-sync messages; raise it to debug WhatsApp issues.
BAILEYS_LOG_LEVEL=silent

# ---- Gemini (extraction) ----
GEMINI_API_KEY=your-gemini-api-key
# Cost-efficient multimodal model with a free tier. Bump to gemini-3.5-flash for hard images.
GEMINI_MODEL=gemini-3.1-flash-lite

# ---- Firebase (Firestore + Storage) ----
FIREBASE_PROJECT_ID=your-project-id
# Path to a service-account JSON key file (used by applicationDefault credentials).
# In Docker, mount it and point here, e.g. /app/secrets/serviceAccount.json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json
# Alternatively, paste the whole service-account JSON inline (takes priority if set).
FIREBASE_SERVICE_ACCOUNT_JSON=
# e.g. your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ---- Geocoding ----
# none | nominatim | google
GEOCODER_PROVIDER=nominatim
# Required only when GEOCODER_PROVIDER=google
GEOCODING_API_KEY=

# ---- Worker ----
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=5
WORKER_MAX_ATTEMPTS=5
# Confidence below this marks the business as needs_review
MIN_CONFIDENCE=0.5
